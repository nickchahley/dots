#!/usr/bin/env bash
NAME=$1
PYTHON_VERSION=${2:-"3.11.5"}
TEST_BASE="_test"

if [[ "$NAME" == "test" ]]; then
	echo "cloning $TEST_BASE to $NAME"
	conda create --yes --name "$NAME" --clone "$TEST_BASE"
else
	conda create --yes python==$PYTHON_VERSION pip --name "$NAME"
	conda run --no-capture-output -n "$NAME" pip install pytest
fi
